{
  "name": "execora-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Execora — Real-time Voice-Driven SME Business Engine (monorepo root)",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@execora/api",
    "dev:web": "turbo run dev --filter=@execora/web",
    "worker": "turbo run dev --filter=@execora/worker",
    "dev:all": "turbo run dev",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@execora/web",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "typecheck:web": "turbo run typecheck --filter=@execora/web",
    "start": "turbo run start --filter=@execora/api",
    "start:worker": "turbo run start --filter=@execora/worker",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "migrate:prod": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "prisma": "^5.9.1"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.3.3",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@10.29.3"
}
