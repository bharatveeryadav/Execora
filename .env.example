# =============================================================================
# Execora — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# For production, inject these via your CI/CD secrets manager or Docker secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
NODE_ENV=development               # development | production | test
PORT=3006
HOST=0.0.0.0
TZ=Asia/Kolkata

# Comma-separated allowed origins for CORS (leave empty to allow all in dev)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# -----------------------------------------------------------------------------
# DATABASE — PostgreSQL (required)
# -----------------------------------------------------------------------------
# Local:      postgresql://user:password@localhost:5432/execora?schema=public
# Supabase:   postgresql://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
# Railway:    postgresql://postgres:[password]@[host]:5432/railway
DATABASE_URL=postgresql://execora:execora@localhost:5432/execora?schema=public


# -----------------------------------------------------------------------------
# REDIS — Cache + BullMQ queues (required)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                    # leave empty for no-auth local dev


# -----------------------------------------------------------------------------
# MINIO — Object Storage for invoices/recordings (required)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=execora
MINIO_USE_SSL=false                # set true in production with HTTPS endpoint


# -----------------------------------------------------------------------------
# LLM — Language Models
#
# Priority chain (automatic, no code changes):
#   Intent extraction:   OpenAI → Ollama
#   Response generation: Groq (fast LPU) → Ollama (local) → OpenAI (fallback)
#
# Minimum required: OPENAI_API_KEY (Groq and Ollama are optional speedups)
# -----------------------------------------------------------------------------

# OpenAI (required — used for intent extraction)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# Groq — fast LPU inference, ~200ms response vs ~1400ms from India (optional)
# Free tier is generous. Get key: https://console.groq.com
GROQ_API_KEY=gsk_...

# Ollama — fully local LLM, no internet required (optional)
# Setup: install ollama → `ollama pull llama3.2` → `ollama serve`
# Docs: https://ollama.com
# Uncomment to enable:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2             # or qwen2.5:7b, phi4, mistral, gemma3


# -----------------------------------------------------------------------------
# STT — Speech-to-Text
#
# STT_PROVIDER controls which adapter is used as primary.
# Auto-fallback to any other available provider.
# Options: deepgram | elevenlabs | whisper
# -----------------------------------------------------------------------------
STT_PROVIDER=deepgram

# Deepgram — best Hindi/Hinglish accuracy, real-time streaming
# Free trial: $200 credit. Get key: https://deepgram.com
DEEPGRAM_API_KEY=

# ElevenLabs STT — alternative to Deepgram (uses same ELEVENLABS_API_KEY below)
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_STT_REALTIME_MODEL=scribe_v2_realtime
ELEVENLABS_STT_LANGUAGE=hi         # hi = Hindi/Hinglish, skip auto-detect for lower latency

# Whisper — local/offline STT via whisper-asr-webservice (batch only, no live streaming)
# Setup: docker run -d -p 9000:9000 -e ASR_MODEL=base onerahmet/openai-whisper-asr-webservice:latest
# Docs: https://github.com/ahmetoner/whisper-asr-webservice
# Uncomment to enable:
# WHISPER_BASE_URL=http://localhost:9000
# WHISPER_MODEL=base                # tiny|base|small|medium|large-v3
# WHISPER_LANGUAGE=hi


# -----------------------------------------------------------------------------
# TTS — Text-to-Speech
#
# TTS_PROVIDER controls which adapter is used as primary.
# Auto-fallback to any other available provider.
# Options: elevenlabs | openai | piper
# -----------------------------------------------------------------------------
TTS_PROVIDER=elevenlabs

# ElevenLabs — best voice quality, supports Hindi/multilingual (optional)
# Free tier: 10k chars/month. Get key: https://elevenlabs.io
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # default: Rachel — replace with your preferred voice

# Piper — local/offline TTS, fully offline, supports Hindi, < 500ms on CPU (optional)
# Setup: docker run -d -p 5000:5000 rhasspy/wyoming-piper --voice hi_IN-deepika-medium
# Docs: https://github.com/rhasspy/piper
# Uncomment to enable:
# PIPER_BASE_URL=http://localhost:5000
# PIPER_VOICE=hi_IN-deepika-medium  # hi_IN-deepika-medium | en_US-lessac-medium


# -----------------------------------------------------------------------------
# WHATSAPP — Cloud API (optional — needed for WhatsApp invoice delivery)
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# -----------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=execora-webhook-secret-change-me
WHATSAPP_API_VERSION=v18.0


# -----------------------------------------------------------------------------
# EMAIL — SMTP (optional — needed for invoice email + OTP-based data deletion)
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false                 # true for SSL (port 465), false for TLS (port 587)
EMAIL_USER=
EMAIL_PASSWORD=                    # Gmail: use App Password (16 chars), not your account password
EMAIL_FROM=Execora <support@yourshop.in>

# Admin account that receives OTP for sensitive operations (e.g. DELETE_CUSTOMER_DATA)
ADMIN_EMAIL=
ADMIN_NAME=Admin
# Bcrypt hash of the admin password. Generate: node -e "require('bcryptjs').hash('yourpass',10).then(console.log)"
# REQUIRED in production — system user login is disabled until this is set.
ADMIN_PASSWORD_HASH=


# -----------------------------------------------------------------------------
# JWT — Business user authentication (/api/v1/auth/*)
# JWT_SECRET: generate with: openssl rand -hex 32   (min 32 chars, keep secret)
# JWT_ACCESS_EXPIRES_SECONDS:  access token TTL  (default 900 = 15 minutes)
# JWT_REFRESH_EXPIRES_SECONDS: refresh token TTL (default 604800 = 7 days)
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_ACCESS_EXPIRES_SECONDS=900
JWT_REFRESH_EXPIRES_SECONDS=604800


# -----------------------------------------------------------------------------
# ADMIN API — protects /admin/* routes and the BullMQ queue dashboard
# Generate: openssl rand -hex 32
# Required in production — admin endpoints return 503 if this is not set.
# -----------------------------------------------------------------------------
ADMIN_API_KEY=


# -----------------------------------------------------------------------------
# SYSTEM BOOTSTRAP — default tenant identity
# -----------------------------------------------------------------------------
SYSTEM_TENANT_ID=system-tenant-001
SYSTEM_USER_ID=system-user-001
BUSINESS_NAME=My Store
# One of: kirana | retail | wholesale | cosmetics | both
BUSINESS_TYPE=retail


# -----------------------------------------------------------------------------
# LOGGING (optional)
# -----------------------------------------------------------------------------
LOG_LEVEL=debug                    # trace | debug | info | warn | error


# -----------------------------------------------------------------------------
# RUNTIME CONFIG (optional — admin panel hot-reloads from Redis)
# -----------------------------------------------------------------------------
# Redis key where the admin panel stores live config overrides
RUNTIME_CONFIG_KEY=execora:runtime-config
# How often (seconds) each server instance polls Redis for config changes
RUNTIME_CONFIG_POLL_SECONDS=60
# LLM cost tracking (USD per 1k tokens — used for cost metrics in Grafana)
OPENAI_COST_INPUT_PER_1K=0.00015
OPENAI_COST_OUTPUT_PER_1K=0.0006


# -----------------------------------------------------------------------------
# WEBSOCKET (optional)
# -----------------------------------------------------------------------------
# Set to false to use the legacy plain WebSocket handler instead of the
# enhanced AudioWorklet + PCM streaming handler
USE_ENHANCED_AUDIO=true
