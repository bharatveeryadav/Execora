{
  "expo": {
    "name": "Execora",
    "slug": "execora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "execora",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.execora.billing",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Execora uses camera to scan barcodes and capture product photos.",
        "NSPhotoLibraryUsageDescription": "Save invoice PDFs to your photo library.",
        "NSMicrophoneUsageDescription": "Execora uses microphone for voice billing commands."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.execora.billing",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        { "cameraPermission": "Execora needs camera to scan barcodes." }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0f172a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
