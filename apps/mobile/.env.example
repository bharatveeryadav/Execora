# API base URL — required for login and all API calls
# Leave empty to use default (emulator only: http://10.0.2.2:3006)
#
# Physical phone: use your PC's LAN IP, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.5:3006
#
# Emulator: default works, or explicitly:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:3006
#
EXPO_PUBLIC_API_URL=

# Optional: auto-login for development
EXPO_PUBLIC_LOGIN_EMAIL=
EXPO_PUBLIC_LOGIN_PASSWORD=
