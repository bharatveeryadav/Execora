    },
    "./logger": {
      "require": "./dist/logger.js",
      "types": "./dist/logger.d.ts"
    },
    "./database": {
      "require": "./dist/database.js",
      "types": "./dist/database.d.ts"
    },
    "./auth": {
      "require": "./dist/auth.js",
      "types": "./dist/auth.d.ts"
    },
    "./metrics": {
      "require": "./dist/metrics.js",
      "types": "./dist/metrics.d.ts"
    },
    "./metrics-plugin": {
      "require": "./dist/metrics-plugin.js",
      "types": "./dist/metrics-plugin.d.ts"
    },
    "./error-handler": {
      "require": "./dist/error-handler.js",
      "types": "./dist/error-handler.d.ts"
    },
    "./queue": {
      "require": "./dist/queue.js",
      "types": "./dist/queue.d.ts"
    },
    "./redis-client": {
      "require": "./dist/redis-client.js",
      "types": "./dist/redis-client.d.ts"
    },
    "./storage": {
      "require": "./dist/storage.js",
      "types": "./dist/storage.d.ts"
