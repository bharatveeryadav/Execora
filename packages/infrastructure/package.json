    "bullmq":          "^5.1.9",
    "date-fns":        "^3.3.1",
    "date-fns-tz":     "^3.1.3",
    "dotenv":          "^16.4.1",
    "fastify":         "^4.26.1",
    "form-data":       "^4.0.0",
    "ioredis":         "^5.3.2",
    "minio":           "^7.1.3",
    "nodemailer":      "^6.9.7",
    "openai":          "^4.28.0",
    "pdfkit":          "^0.17.2",
    "pino":            "^8.19.0",
