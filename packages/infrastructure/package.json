    "./error-handler":  { "require": "./dist/error-handler.js",  "types": "./dist/error-handler.d.ts" },
    "./queue":      { "require": "./dist/queue.js",          "types": "./dist/queue.d.ts" },
    "./redis-client": { "require": "./dist/redis-client.js", "types": "./dist/redis-client.d.ts" },
    "./storage":    { "require": "./dist/storage.js",        "types": "./dist/storage.d.ts" },
