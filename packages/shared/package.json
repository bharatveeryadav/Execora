{
  "name": "@execora/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Platform-agnostic business logic — usable in web (React/Vite) and mobile (React Native/Expo)",
  "main": "./dist/index.js",
  "source": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
