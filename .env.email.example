# Email configuration is now consolidated in .env.example
# See the EMAIL_* section there for all SMTP options (Gmail, SendGrid, Brevo).
#
# Quick reference:
#
# Gmail App Password (recommended over plain password):
#   Google Account → Security → 2-Step Verification → App passwords → Generate
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_USER=you@gmail.com
#   EMAIL_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char app password, not your account password
#
# SendGrid (recommended for production — reliable delivery):
#   EMAIL_HOST=smtp.sendgrid.net
#   EMAIL_USER=apikey
#   EMAIL_PASSWORD=SG.your_sendgrid_api_key
#
# Brevo / Sendinblue (free 300 emails/day):
#   EMAIL_HOST=smtp-relay.brevo.com
#   EMAIL_USER=your@email.com
#   EMAIL_PASSWORD=your_brevo_smtp_key
